# ─────────────────────────────────────────────────────────────────────────────
# vibrationofawesome.com — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (required for post generation + captions) ───────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Pexels (image selection — get free key at pexels.com/api) ─────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── Dashboard password ────────────────────────────────────────────────────────
# Used to protect /dashboard/. Run syndicate.js once after setting this and
# it will auto-generate static/_data/dashboard-config.json with the SHA-256 hash.
DASHBOARD_PASSWORD=your_secure_dashboard_password

# ── Bluesky ───────────────────────────────────────────────────────────────────
# Handle: your full handle e.g. vibrationofawesome.bsky.social
# App Password: generate one at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password-here

# ── Mastodon ──────────────────────────────────────────────────────────────────
# Instance: full URL e.g. https://mastodon.social
# Access Token: generate at Settings > Development > New Application
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_mastodon_access_token

# ── Facebook / Meta ───────────────────────────────────────────────────────────
# App credentials (needed for long-lived token exchange — optional but recommended)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# VOA Facebook Page
META_PAGE_ID_VOA=your_voa_facebook_page_id
META_PAGE_TOKEN_VOA=your_voa_page_access_token

# EarthStar Facebook Page
META_PAGE_ID_EARTHSTAR=your_earthstar_facebook_page_id
META_PAGE_TOKEN_EARTHSTAR=your_earthstar_page_access_token

# ── Pinterest ─────────────────────────────────────────────────────────────────
# OAuth 2.0 access token — obtain via Pinterest Developer portal OAuth flow
# https://developers.pinterest.com/docs/getting-started/authentication/
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_ACCESS_TOKEN=your_pinterest_oauth_access_token
PINTEREST_BOARD_ID=your_target_board_id

# ── Dev.to ────────────────────────────────────────────────────────────────────
# Generate at https://dev.to/settings/extensions (API Keys section)
DEVTO_API_KEY=your_devto_api_key

# ── Hashnode ──────────────────────────────────────────────────────────────────
# API key: https://hashnode.com/settings/developer
# Publication ID: found in your Hashnode publication dashboard > Settings > Advanced
# Blog slug: your-blog.hashnode.dev or custom domain slug
HASHNODE_API_KEY=your_hashnode_api_key
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id
HASHNODE_BLOG_SLUG=your-blog

# ── Tumblr ────────────────────────────────────────────────────────────────────
# Create app at https://www.tumblr.com/oauth/apps
# Blog name: your-blog (without .tumblr.com)
TUMBLR_CONSUMER_KEY=your_tumblr_consumer_key
TUMBLR_CONSUMER_SECRET=your_tumblr_consumer_secret
TUMBLR_TOKEN=your_tumblr_oauth_token
TUMBLR_TOKEN_SECRET=your_tumblr_oauth_token_secret
TUMBLR_BLOG_NAME=your-tumblr-blog-name

# ── Instagram + Threads (via Publer) ─────────────────────────────────────────
# Publer is a social media scheduler that handles Instagram/Threads posting.
# API key: https://app.publer.io/account/api — verify exact endpoint/payload
# format against Publer's latest API docs if you encounter errors.
PUBLER_API_KEY=your_publer_api_key
